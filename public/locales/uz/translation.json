  "faqSection": {
    "subtitle": "KO'P SO'RALADIGAN SAVOLLAR",
    "title": "Tez-tez So'raladigan Savollar",
    "faq1": {
      "question": "Kutubxonaga a'zo bo'lish uchun nima kerak?",
      "answer": "Kutubxonaga a'zo bo'lish uchun passport yoki ID kartangiz bilan kutubxonaga tashrif buyurishingiz kerak. Ro'yxatdan o'tish bepul va bir necha daqiqada tugaydi. Onlayn ro'yxatdan o'tish ham mavjud."
    },
    "faq2": {
      "question": "Kitoblarni qancha vaqtga olish mumkin?",
      "answer": "Oddiy kitoblarni 21 kungacha, ilmiy adabiyotlarni 14 kungacha olish mumkin. Muddatni uzaytirish imkoniyati ham mavjud. Raqamli kitoblar cheksiz vaqt uchun ochiq."
    },
    "faq3": {
      "question": "Raqamli kutubxonadan qanday foydalanish mumkin?",
      "answer": "Raqamli kutubxonadan foydalanish uchun kutubxona a'zosi bo'lishingiz kerak. Shaxsiy kabinetingizdan minglab elektron kitoblar, jurnallar va multimedia resurslarga kirish imkoniyati bor."
    },
    "faq4": {
      "question": "Kutubxona xizmatlari pullikmi?",
      "answer": "Kutubxona a'zoligi va asosiy xizmatlar bepul. Fotokopiya, chop etish va ba'zi maxsus tadbirlar uchun kichik to'lovlar olinadi. Student va nafaqaxo'rlar uchun chegirmalar mavjud."
    },
    "faq5": {
      "question": "Kutubxona ishlash vaqti qanday?",
      "answer": "Kutubxona dushanba-shanbagacha 8:00 dan 18:30 gacha ishlaydi. Yakshanba dam olish kuni. Ba'zi filiallar kechki soatlargacha ishlaydi. Raqamli xizmatlar 24/7 ochiq."
    }
  },
