  "faqSection": {
    "subtitle": "FREQUENTLY ASKED QUESTIONS",
    "title": "Frequently Asked Questions",
    "faq1": {
      "question": "What do I need to become a library member?",
      "answer": "To become a library member, you need to visit the library with your passport or ID card. Registration is free and takes just a few minutes. Online registration is also available."
    },
    "faq2": {
      "question": "How long can I borrow books?",
      "answer": "Regular books can be borrowed for up to 21 days, scientific literature for 14 days. Extension is possible. Digital books are available indefinitely."
    },
    "faq3": {
      "question": "How can I use the digital library?",
      "answer": "To use the digital library, you need to be a library member. Through your personal account, you can access thousands of e-books, journals, and multimedia resources."
    },
    "faq4": {
      "question": "Are library services paid?",
      "answer": "Library membership and basic services are free. Small fees are charged for photocopying, printing, and some special events. Discounts are available for students and seniors."
    },
    "faq5": {
      "question": "What are the library hours?",
      "answer": "The library is open Monday to Saturday from 8:00 AM to 6:30 PM. Sunday is closed. Some branches have extended evening hours. Digital services are available 24/7."
    }
  },
